# Environment Variables for TaxiGo Web

# API base URL (replace with your backend URL)
VITE_API_BASE_URL=http://localhost:8000/api

# App title
VITE_APP_TITLE=TaxiGo Web

# Enable MSW mock API (set to 'true' for dev without backend)
VITE_USE_MOCK=true

# Google Maps API key (optional, for Leaflet alternatives)
# VITE_GOOGLE_MAPS_KEY=your_key_here
